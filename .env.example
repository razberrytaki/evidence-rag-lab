# Live ingest and live generation require an OpenAI key because embeddings are fixed to OpenAI.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64

# Default live generation provider.
LLM_PROVIDER=openai-compatible
OPENAI_CHAT_MODEL=gpt-5.4-mini

# Optional generation-only comparison adapter.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# CI and deterministic local eval should use fake.
EVAL_LLM_PROVIDER=fake
TRACE_SANITIZE=true
TRACE_RETENTION_DAYS=7
RAG_QUERY_MODE=sample

DATABASE_URL=postgres://evidence:rag@localhost:5432/evidence_rag_lab
